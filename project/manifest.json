{
  "manifest_version": 3,
  "name": "Instant Dictionary & Translator",
  "version": "1.0",
  "description": "Double-click words to get meaning, pronunciation, and audio",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.dictionaryapi.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["tooltip.css"]
    }
  ]
}